# Datadog credentials
DD_API_KEY=
DD_APP_KEY=                              # Optional: only needed for API-based features (e.g. IP blocking in AAP)
DD_SITE=datadoghq.com

# Product toggles (set by ./scripts/up.sh, or edit manually)
DD_APPSEC_ENABLED=false                  # AAP: App & API Protection (WAF, attack detection)
DD_IAST_ENABLED=false                    # IAST: tainted data flow analysis
DD_APPSEC_SCA_ENABLED=false              # SCA: vulnerable dependency scanning
DD_SYSTEM_PROBE_ENABLED=false            # CWS: system-probe for eBPF runtime security
DD_RUNTIME_SECURITY_CONFIG_ENABLED=false # CWS: runtime security detections

# Database
POSTGRES_DB=petshop
POSTGRES_USER=petshop
POSTGRES_PASSWORD=petshop123
