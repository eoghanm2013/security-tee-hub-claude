<%- include('header', { title: 'Bits & Bytes Pet Shop' }) %>

<h1>Welcome to Bits &amp; Bytes Pet Shop</h1>
<p style="color:var(--dd-text-light);margin-bottom:1rem;">Datadog-themed pet supplies for the discerning pup. Browse our collection below.</p>

<form action="<%= prefix %>/search" method="get" class="search-bar">
    <input type="text" name="q" placeholder="Search products...">
    <button type="submit" class="btn">Search</button>
</form>

<div class="product-grid">
    <% products.forEach(function(p) { %>
    <a href="<%= prefix %>/product/<%= p.id %>" style="text-decoration:none;color:inherit;">
        <div class="product-card">
            <div class="emoji"><%= p.image_emoji %></div>
            <span class="category"><%= p.category %></span>
            <h3><%= p.name %></h3>
            <span class="price">$<%= parseFloat(p.price).toFixed(2) %></span>
        </div>
    </a>
    <% }); %>
</div>

<%- include('footer') %>
